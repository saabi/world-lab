{
	"name": "virtual-planet",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"start": "node build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"postinstall": "node scripts/ensure-rolldown-binding.mjs",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"build:wasm": "asc assembly/scheduler.ts --outFile src/lib/planet/patches/wasm/scheduler.wasm --runtime stub --optimize",
		"sundog:export": "node --experimental-strip-types --no-warnings scripts/sundog/export-catalog.ts",
		"test": "vitest run"
	},
	"dependencies": {
		"@virtual-planet/schema": "^0.0.0",
		"@virtual-planet/subdivide": "^0.0.0",
		"three": "^0.175.0"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^25.9.2",
		"@types/three": "^0.175.0",
		"@webgpu/types": "^0.1.70",
		"assemblyscript": "^0.28.19",
		"glslify": "^7.1.1",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.9"
	},
	"optionalDependencies": {
		"@rolldown/binding-darwin-arm64": "1.0.3",
		"@rolldown/binding-darwin-x64": "1.0.3",
		"@rolldown/binding-linux-x64-gnu": "1.0.3",
		"@rolldown/binding-linux-x64-musl": "1.0.3",
		"@rolldown/binding-win32-x64-msvc": "1.0.3"
	}
}
