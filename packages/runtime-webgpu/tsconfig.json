{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true,
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"types": ["@webgpu/types", "node"],
		"customConditions": ["development"]
	},
	"include": [
		"src/**/*"
	]
}
