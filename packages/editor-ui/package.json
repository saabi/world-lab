{
	"name": "@world-lab/editor-ui",
	"version": "0.0.0",
	"private": true,
	"license": "MIT",
	"description": "Shared Svelte editor chrome and parameter controls (sections, tabs, sliders, checkboxes).",
	"repository": {
		"type": "git",
		"url": "https://github.com/saabi/world-lab.git",
		"directory": "packages/editor-ui"
	},
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"development": "./src/index.ts",
			"import": "./dist/index.js"
		},
		"./Section.svelte": {
			"types": "./dist/Section.svelte.d.ts",
			"development": "./src/Section.svelte",
			"svelte": "./dist/Section.svelte"
		},
		"./Subsection.svelte": {
			"types": "./dist/Subsection.svelte.d.ts",
			"development": "./src/Subsection.svelte",
			"svelte": "./dist/Subsection.svelte"
		},
		"./VerticalTabs.svelte": {
			"types": "./dist/VerticalTabs.svelte.d.ts",
			"development": "./src/VerticalTabs.svelte",
			"svelte": "./dist/VerticalTabs.svelte"
		},
		"./TabIcon.svelte": {
			"types": "./dist/TabIcon.svelte.d.ts",
			"development": "./src/TabIcon.svelte",
			"svelte": "./dist/TabIcon.svelte"
		},
		"./controls/SliderRow.svelte": {
			"types": "./dist/controls/SliderRow.svelte.d.ts",
			"development": "./src/controls/SliderRow.svelte",
			"svelte": "./dist/controls/SliderRow.svelte"
		},
		"./controls/Range.svelte": {
			"types": "./dist/controls/Range.svelte.d.ts",
			"development": "./src/controls/Range.svelte",
			"svelte": "./dist/controls/Range.svelte"
		},
		"./controls/LogRange.svelte": {
			"types": "./dist/controls/LogRange.svelte.d.ts",
			"development": "./src/controls/LogRange.svelte",
			"svelte": "./dist/controls/LogRange.svelte"
		},
		"./controls/CheckBox.svelte": {
			"types": "./dist/controls/CheckBox.svelte.d.ts",
			"development": "./src/controls/CheckBox.svelte",
			"svelte": "./dist/controls/CheckBox.svelte"
		},
		"./controls/sliderList.css": "./dist/controls/sliderList.css",
		"./package.json": "./package.json"
	},
	"scripts": {
		"check": "tsc --noEmit",
		"test": "vitest run",
		"build": "svelte-package --input src --output dist && node ../../scripts/clean-package-dist-tests.mjs dist"
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@testing-library/svelte": "^5.4.2",
		"@testing-library/user-event": "^14.6.1",
		"happy-dom": "^20.10.6",
		"svelte": "^5.56.4",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9"
	},
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"sideEffects": false
}
