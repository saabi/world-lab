{
	"name": "@world-lab/subdivide",
	"version": "0.0.0",
	"private": true,
	"license": "SEE LICENSE IN LICENSE",
	"description": "Blender-style resizable pane layouts for Svelte 5 — layout tree engine ported from saabi/svelte-subdivide.",
	"repository": {
		"type": "git",
		"url": "https://github.com/saabi/world-lab.git",
		"directory": "packages/subdivide"
	},
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"development": "./src/index.ts",
			"import": "./dist/index.js"
		},
		"./Subdivide.svelte": {
			"types": "./dist/Subdivide.svelte.d.ts",
			"development": "./src/Subdivide.svelte",
			"svelte": "./dist/Subdivide.svelte"
		},
		"./Pane.svelte": {
			"types": "./dist/Pane.svelte.d.ts",
			"development": "./src/Pane.svelte",
			"svelte": "./dist/Pane.svelte"
		},
		"./Divider.svelte": {
			"types": "./dist/Divider.svelte.d.ts",
			"development": "./src/Divider.svelte",
			"svelte": "./dist/Divider.svelte"
		},
		"./PaneHeader.svelte": {
			"types": "./dist/PaneHeader.svelte.d.ts",
			"development": "./src/PaneHeader.svelte",
			"svelte": "./dist/PaneHeader.svelte"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"check": "tsc --noEmit",
		"test": "vitest run",
		"build": "svelte-package --input src --output dist && node ../../scripts/clean-package-dist-tests.mjs dist"
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@testing-library/svelte": "^5.4.2",
		"happy-dom": "^20.10.6",
		"svelte": "^5.56.4",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9"
	},
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"sideEffects": false
}
